[agent]
expertMode = true
stack = "BEST_EFFORT_FALLBACK"

[nix]
channel = "stable-25_05"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "gcc tdas/list.c tdas/map.c tdas/heap.c tdas/extra.c tarea3.c -Wno-unused-result -o tarea3 && ./tarea3"

[workflows.workflow.metadata]
outputType = "console"

[deployment]
deploymentTarget = "vm"
run = ["./tarea3"]
build = ["bash", "-c", "gcc tdas/list.c tdas/map.c tdas/heap.c tdas/extra.c tarea3.c -Wno-unused-result -o tarea3"]
